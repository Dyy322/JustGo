<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.dyu.justgobackend.mapper.activity.ActivityTagRelMapper">

    <insert id="insertBatch">
        INSERT INTO activity_tag_rel (activity_id, tag_id) VALUES
        <foreach collection="tagIds" item="tagId" separator=",">
            (#{activityId}, #{tagId})
        </foreach>
    </insert>

    <select id="selectTagNamesByActivityIds" resultType="map">
        SELECT rel.activity_id AS activityId, at.name AS tagName
        FROM activity_tag_rel rel
        JOIN activity_tag at ON rel.tag_id = at.id
        WHERE rel.activity_id IN
        <foreach collection="activityIds" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
        ORDER BY rel.activity_id, at.name
    </select>

    <delete id="deleteByActivityId">
        DELETE FROM activity_tag_rel WHERE activity_id = #{activityId}
    </delete>

    <delete id="deleteByTagId">
        DELETE FROM activity_tag_rel WHERE tag_id = #{tagId}
    </delete>

</mapper>
